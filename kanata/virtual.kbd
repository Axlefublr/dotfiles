(defvirtualkeys
	a (multi (layerâ†‘ a) (layerâ†‘ ag))
	c (multi (layerâ†‘ c) (layerâ†‘ cx) (layerâ†‘ cv))
	e (multi (layerâ†‘ e) (layerâ†‘ ew) (layerâ†‘ ef) (layerâ†‘ er) (layerâ†‘ efw) (layerâ†‘ erw))
	f (multi (layerâ†‘ f) (layerâ†‘ ef) (layerâ†‘ fw) (layerâ†‘ efw))
	g (multi (layerâ†‘ g) (layerâ†‘ ag))
	h (multi (layerâ†‘ h) (layerâ†‘ semicolon-h))
	i (multi (layerâ†‘ i) (layerâ†‘ ij) (layerâ†‘ io) (layerâ†‘ iu) (layerâ†‘ ijo))
	j (multi (switch
		((layer bookmark-set)) (one-shot $ot (layer-toggle bookmark-set)) break
		) (layerâ†‘ j) (layerâ†‘ ij) (layerâ†‘ jo) (layerâ†‘ ijo) (layerâ†‘ quote-j)
	)
	n (multi (layerâ†‘ n) (layerâ†‘ quote-n))
	o (multi (layerâ†‘ o) (layerâ†‘ jo) (layerâ†‘ io) (layerâ†‘ ijo))
	r (multi (layerâ†‘ r) (layerâ†‘ er) (layerâ†‘ rw) (layerâ†‘ erw))
	u (multi (layerâ†‘ u) (layerâ†‘ iu))
	v (multi (layerâ†‘ v) (layerâ†‘ cv) (layerâ†‘ vx))
	w (multi (layerâ†‘ w) (layerâ†‘ fw) (layerâ†‘ ew) (layerâ†‘ efw) (layerâ†‘ rw) (layerâ†‘ erw))
	x (multi (layerâ†‘ x) (layerâ†‘ cx) (layerâ†‘ vx))
	caps (multi (layerâ†‘ caps) (layerâ†‘ caps-space))
	quote (multi (switch
			((layer bookmark)) (one-shot $ot (layer-toggle bookmark)) break
			((layer bookmark-set)) (one-shot $ot (layer-toggle bookmark-set)) break
		) (layerâ†‘ quote) (layerâ†‘ space-quote) (layerâ†‘ quote-j) (layerâ†‘ quote-n)
	)
	semicolon (multi (layerâ†‘ semicolon) (layerâ†‘ semicolon-h))

	shift lsft
	ctrl  lctl
	alt   lalt
	meta  lmet
	modifier (multi (onâ†“ release-vkey shift) (onâ†“ release-vkey ctrl) (onâ†“ release-vkey alt) (onâ†“ release-vkey meta))
	modifier-zoom (multi (onâ†“ tap-vkey modifier) (cmd niri msg action set-zoom-level 1))
	space (switch ((not (layer space)))
		(multi (layerâ†‘ space) (layerâ†‘ caps-space) (layerâ†‘ space-quote) (onâ†“ tap-vkey modifier))
	break)

	disable-mouse-mode (multi (cmd fish -c "echo >~/.local/share/mine/waybar-mouse-mode") (onâ†“ tap-vkey space))
	mouse-mode (multi (cmd fish -c "echo ó°‡€ >~/.local/share/mine/waybar-mouse-mode") (layer-toggle space) (onâ†‘ tap-vkey disable-mouse-mode))

	nuclear-throne (layer-toggle nuclear-throne)
	enter-the-gungeon (layer-toggle enter-the-gungeon)
	slay-the-spire (layer-toggle slay-the-spire)
	plants-vs-zombies (layer-toggle plants-vs-zombies)
)
